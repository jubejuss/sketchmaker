# ── Dependencies ────────────────────────────────────────────
node_modules/
.npm
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity

# ── Build output ────────────────────────────────────────────
# electron-vite writes to out/, electron-builder writes to dist/ (per package.json build.directories.output)
out/
dist/
build/
release/
app/

# electron-builder reads app icons from build/ — keep those tracked
!build/
build/icon.iconset/
!build/icon.svg
!build/icon.png
!build/icon.icns

# electron-builder installers / signed artifacts (in case built outside dist/)
*.dmg
*.dmg.blockmap
*.pkg
*.mas
*.app
*.exe
*.blockmap
*.nupkg
*.appx
*.snap
*.deb
*.rpm
*.AppImage

# ── Caches ──────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
electron.vite.config.js.timestamp-*
electron.vite.config.ts.timestamp-*
*.tsbuildinfo
.cache/
.eslintcache
.stylelintcache

# ── Playwright ──────────────────────────────────────────────
# scraper uses playwright-core; if tests are added later these cover them too
playwright-report/
test-results/
.playwright/
playwright/.cache/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Env / secrets ───────────────────────────────────────────
.env
.env.*
!.env.example

# Code-signing certs & keys (electron-builder mac/win signing)
*.pem
*.key
*.p12
*.pfx
*.cer
*.mobileprovision
*.keystore

# ── Generated project output ────────────────────────────────
# If outputDir is ever pointed at the repo, PDFs/HTML/images should not be committed
stiilileidja-output/

# ── Coverage / testing ──────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── IDE ─────────────────────────────────────────────────────
.vscode/
.vscode-test/
.idea/
*.swp
*.swo

# ── Local Claude / agent memory (user-specific) ─────────────
.claude/

# ── OS ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db

# ── Runtime ─────────────────────────────────────────────────
pids/
*.pid
*.pid.lock
*.seed

# ── Output of `npm pack` ────────────────────────────────────
*.tgz

# ── Diagnostic reports (Node) ───────────────────────────────
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
